  "utilities": {
    "_comment": "Helper functions for theme usage",
    "get_random_theme": "Object.keys(themes)[Math.floor(Math.random() * Object.keys(themes).length)]",
    "css_variables": {
      "_comment": "Generate CSS custom properties from a theme",
      "template": [
        ":root {",
        "  --color-primary: {primary};",
        "  --color-secondary: {secondary};",
        "  --color-accent: {accent};",
        "  --color-background: {background};",
        "  --color-surface: {surface};",
        "  --color-text: {text};",
        "  --color-text-muted: {text_muted};",
        "  --color-heading: {heading};",
        "  --color-link: {link};",
        "  --color-link-hover: {link_hover};",
        "  --color-code-bg: {code_bg};",
        "  --color-code-text: {code_text};",
        "  --color-border: {border};",
        "  --color-success: {success};",
        "  --color-warning: {warning};",
        "  --color-error: {error};",
        "  --gradient-main: {gradient};",
        "}"
      ]
    },
    "scss_variables": {
      "_comment": "Generate SCSS variables from a theme",
      "template": [
        "$color-primary: {primary};",
        "$color-secondary: {secondary};",
        "$color-accent: {accent};",
        "$color-background: {background};",
        "$color-surface: {surface};",
        "$color-text: {text};",
        "$color-text-muted: {text_muted};",
        "$color-heading: {heading};",
        "$color-link: {link};",
        "$color-link-hover: {link_hover};",
        "$color-code-bg: {code_bg};",
        "$color-code-text: {code_text};",
        "$color-border: {border};",
        "$color-success: {success};",
        "$color-warning: {warning};",
        "$color-error: {error};",
        "$gradient-main: {gradient};"
      ]
    }
  }
